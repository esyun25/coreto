{
  "name": "corebldg-mas",
  "version": "1.0.0",
  "description": "COREBLDG マルチエージェントシミュレーションシステム",
  "scripts": {
    "start":      "node run.js --count=100",
    "quick":      "node run.js --count=20 --concurrency=2",
    "full":       "node run.js --count=1000 --concurrency=5",
    "resume":     "node run.js --resume",
    "report":     "node run.js --report-only",
    "review":     "node review.js",
    "approve":    "node approve.js",
    "approve:all":"node approve.js all"
  },
  "dependencies": {
    "playwright": "^1.56.0"
  }
}
