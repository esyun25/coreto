// ================================================================
//  チェックリスト定義
// ================================================================
const CHECKLISTS = {
  re: {
    estTime: '15〜30分',
    sections: [
      {
        id:'basic', icon:'👤', title:'基本情報確認', time:'約2分',
        items:[
          { id:'name',    label:'氏名・フリガナの一致確認',     desc:'申請フォームの氏名とフリガナが正確に記載されているか' },
          { id:'age',     label:'年齢確認（18歳以上）',         desc:'生年月日から計算し18歳以上であることを確認',
            autoCheck: app => app.age < 18 ? 'ng' : null,
            ngAlert: '18歳未満のため即時不合格' },
          { id:'addr',    label:'住所・連絡先の有効性確認',     desc:'郵便番号・住所・メール・電話が有効な形式か' },
          { id:'indiv',   label:'個人事業主確認（法人不可）',   desc:'不動産エージェントは宅建業法により個人契約のみ。法人希望の場合は即不合格',
            ngTag:'即不合格', ngAlert:'法人契約希望の場合は即時不合格' },
        ]
      },
      {
        id:'antisocial', icon:'🔍', title:'反社チェック', time:'約2分',
        items:[
          { id:'google',  label:'Google検索チェック',           desc:'氏名・住所で検索し反社・詐欺・犯罪歴等の情報がないか確認' },
          { id:'kintone', label:'Kintone内部DB照合',            desc:'過去の除名・トラブル事例と照合',
            ngTag:'即不合格', ngAlert:'過去除名記録がある場合は即時不合格' },
        ]
      },
      {
        id:'takken', icon:'📜', title:'宅建士資格確認', time:'約5分',
        items:[
          { id:'tk-held',  label:'資格保有有無の確認',          desc:'申請フォームの回答を確認（保有していない場合は以下をスキップ）' },
          { id:'tk-fmt',   label:'登録番号の形式チェック',      desc:'形式：都道府県名（数字）登録番号　例：東京(2)098765',
            hint:'保有者のみ' },
          { id:'tk-exp',   label:'有効期限内か確認',            desc:'宅建士証の有効期限が現在日付より後であることを確認',
            hint:'保有者のみ' },
          { id:'tk-img',   label:'宅建士証画像の真正性確認',    desc:'・氏名と番号が申請と一致　・画像が鮮明　・偽造の疑いなし',
            hint:'保有者のみ' },
          { id:'tk-db',    label:'国交省DBとの照合',
            desc:'<a href="https://www.retio.or.jp/" target="_blank">🔗 retio.or.jp（国交省DB）</a>　で登録番号を照合し、氏名・有効期限が一致するか確認',
            hint:'保有者のみ', ngTag:'即不合格' },
        ]
      },
      {
        id:'career', icon:'💼', title:'職歴・経験確認', time:'約5分',
        items:[
