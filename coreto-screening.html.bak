          { id:'name',   label:'氏名・フリガナの一致確認',      desc:'申請フォームの氏名とフリガナが正確に記載されているか' },
          { id:'age',    label:'年齢確認（18歳以上）',          desc:'生年月日から計算し18歳以上であることを確認',
            autoCheck: app => app.age < 18 ? 'ng' : null,
            ngAlert:'18歳未満のため即時不合格' },
          { id:'addr',   label:'住所・連絡先の有効性確認',      desc:'郵便番号・住所・メール・電話が有効な形式か' },
          { id:'indiv',  label:'個人事業主確認（法人不可）',    desc:'人材エージェントは職業安定法により個人契約のみ',
            ngTag:'即不合格' },
        ]
      },
      {
        id:'antisocial', icon:'🔍', title:'反社チェック', time:'約2分',
        items:[
          { id:'google',  label:'Google検索チェック',           desc:'氏名・住所で検索し反社・詐欺・犯罪歴等の情報がないか確認' },
          { id:'kintone', label:'Kintone内部DB照合',            desc:'過去の除名・トラブル事例と照合',
            ngTag:'即不合格' },
        ]
      },
      {
        id:'hrexp', icon:'🏢', title:'人材業界経験確認 ★最重要', time:'約7分',
        items:[
          { id:'exp-yr',  label:'業界経験年数の確認',
            desc:'<span class="tag tag-ng">1年未満：即不合格</span>　<span class="tag tag-ng">未経験：即不合格</span>　1〜3年：OK　3年以上：優遇',
            autoCheck: app => {
              if (app.experience === '1年未満' || app.experience === '未経験') return 'ng';
              if (app.experience === '3年以上') return 'ok';
              return null;
            },
            ngAlert:'人材業界経験1年未満または未経験のため即時不合格（必須要件）',
            instantFail: true,
          },
          { id:'jobtype', label:'業務内容の確認',
            desc:'<span class="tag tag-ok">CA / RA / 両面型：合格</span>　<span class="tag tag-warn">人材営業のみ：面接で確認</span>　<span class="tag tag-ng">事務・受付のみ：不合格</span>',
            autoCheck: app => {
              if (!app.jobTypes) return null;
              if (app.jobTypes.some(t => t.includes('事務'))) return 'ng';
              if (app.jobTypes.some(t => t.includes('CA') || t.includes('RA') || t.includes('両面'))) return 'ok';
              return null;
            },
          },
          { id:'exp-det', label:'実績・職歴の具体性確認',       desc:'担当業界・年間支援件数・得意職種が具体的に記載されているか' },
        ]
      },
      {
        id:'specialty', icon:'🎯', title:'専門分野確認', time:'約3分',
        items:[
          { id:'industry', label:'得意業界・職種の確認',        desc:'特化分野が明確か。カバレッジの広さより深さを重視' },
        ]
      },
      {
        id:'motivation', icon:'📝', title:'志望動機確認', time:'約3分',
        items:[
          { id:'mot-len',  label:'志望動機 100文字以上',
            autoCheck: app => app.motivation && app.motivation.length >= 100 ? 'ok' : 'ng',
            ngAlert: '100文字未満' },
          { id:'mot-qual', label:'志望動機の具体性・誠実さ',   desc:'独立志向・実績への言及・フリーランス経験の有無など' },
        ]
      },
    ]
  },
  pt: {
    estTime: '5〜10分',
    sections: [
      {
        id:'basic', icon:'👤', title:'基本情報確認', time:'約2分',
        items:[
          { id:'name',   label:'氏名（または法人名）の確認',    desc:'個人の場合：氏名・フリガナ　法人の場合：法人名・代表者名の確認' },
          { id:'age',    label:'年齢確認（18歳以上）',          desc:'個人の場合のみ（法人はスキップ可）',
            autoCheck: app => (!app.corpName && app.age < 18) ? 'ng' : null,
            ngAlert:'18歳未満のため即時不合格' },
          { id:'addr',   label:'住所・連絡先の有効性確認',      desc:'郵便番号・住所・メール・電話が有効な形式か' },
        ]
      },
      {
        id:'antisocial', icon:'🔍', title:'反社チェック', time:'約2分',
        items:[
          { id:'google',  label:'Google検索チェック',           desc:'氏名・法人名で検索し反社・詐欺等の情報がないか確認' },
          { id:'kintone', label:'Kintone内部DB照合',            desc:'過去の除名・トラブル事例と照合',
            ngTag:'即不合格' },
        ]
      },
      {
        id:'corp', icon:'🏢', title:'法人確認（法人の場合のみ）', time:'約3分',
        items:[
          { id:'corp-no',  label:'法人番号の確認（国税庁DB）',
            desc:'<a href="https://www.houjin-bangou.nta.go.jp/" target="_blank">🔗 国税庁 法人番号公表サイト</a>　で法人番号を照合',
            hint:'法人パートナーのみ' },
          { id:'corp-rep', label:'代表者の確認',               desc:'登記情報と申請の代表者名が一致するか',
            hint:'法人パートナーのみ' },
        ]
      },
      {
        id:'job', icon:'💼', title:'職業・ネットワーク確認', time:'約1分',
        items:[
          { id:'occupation', label:'職業・立場の確認',          desc:'どのような顧客ネットワークを持つか。個人・企業どちらの紹介が主か' },
        ]
      },
      {
        id:'motivation', icon:'📝', title:'志望動機確認', time:'約3分',
        items:[
          { id:'mot-len',  label:'志望動機 50文字以上',
            autoCheck: app => app.motivation && app.motivation.length >= 50 ? 'ok' : 'ng',
            ngAlert: '50文字未満のため不合格リスクあり（冷やかし判定）' },
          { id:'mot-qual', label:'志望動機の具体性確認',        desc:'冷やかし・極端に短い内容でないか。紹介ルートの具体性があるか' },
        ]
      },
      {
        id:'referral', icon:'🔗', title:'紹介者確認', time:'約1分',
        items:[
          { id:'ref-chk', label:'紹介コード確認・紹介者ランク確認', desc:'Goldランク以上の紹介者がいる場合は審査を優遇。特別紹介コードの場合は条件確認' },
        ]
      },
    ]
  }
};

// ================================================================
//  State
// ================================================================
let currentApp  = null;
let checkState  = {};  // { itemId: 'ok'|'ng'|'skip'|null }
let currentVerdict = null;
let timerStart  = null;
let timerInterval = null;
let currentFilter = 'all';

// ================================================================
//  Init
// ================================================================
window.addEventListener('DOMContentLoaded', () => {
  renderAppList();
});

// ================================================================
//  Applicant list
// ================================================================
function renderAppList() {
  const list  = document.getElementById('app-list');
  const apps  = APPLICANTS.filter(a =>
    currentFilter === 'all' || a.type === currentFilter
  );
  document.getElementById('pending-count').textContent =
    APPLICANTS.filter(a => a.status === 'pending').length + ' 件';

  const TYPE = { re:'不動産AG', hr:'人材AG', pt:'Partner' };
  const TYPE_CLS = { re:'t-re', hr:'t-hr', pt:'t-pt' };
  const STATUS_CLS = { pending:'s-pending', pass:'s-pass', fail:'s-fail', hold:'s-hold' };

  list.innerHTML = apps.map(a => `
    <div class="app-card ${currentApp&&currentApp.id===a.id?'active':''}"
         onclick="selectApp('${a.id}')">
      <div class="ac-status ${STATUS_CLS[a.status]||'s-pending'}"></div>
      <div class="ac-name">${escHtml(a.name)}</div>
      <div class="ac-meta">
        <span class="ac-type ${TYPE_CLS[a.type]}">${TYPE[a.type]}</span>
        <span class="ac-time">${a.applied.slice(5,10)} 申請</span>
        ${a.referralCode ? '<span style="font-size:9px;color:var(--gold)">🔗 紹介あり</span>' : ''}
      </div>
    </div>`).join('');
}

function filterApps(f, btn) {
  currentFilter = f;
  document.querySelectorAll('.sf-btn').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  renderAppList();
}

// ================================================================
//  Select applicant
// ================================================================
function selectApp(id) {
  const app = APPLICANTS.find(a => a.id === id);
  if (!app) return;
  currentApp = app;
  checkState = {};
  currentVerdict = null;
  // AI解析リセット
  aiDocResults = {};
  var aiPanel = document.getElementById('ai-doc-panel');
  if (aiPanel) {
    aiPanel.style.display = 'block';
    document.getElementById('ai-doc-extracted').style.display = 'none';
    document.getElementById('ai-doc-result-badge').textContent = '書類をアップロードすると自動解析します';
    document.getElementById('ai-id-btn').innerHTML = '<div style="font-size:18px;margin-bottom:4px">🪪</div>身分証をアップロード';
    document.getElementById('ai-id-btn').style.borderColor = '';
    document.getElementById('ai-id-btn').style.background = '';
    var tkBtn = document.getElementById('ai-takken-btn');
    tkBtn.innerHTML = '<div style="font-size:18px;margin-bottom:4px">📜</div>宅建士証をアップロード';
    tkBtn.style.borderColor = '';
    tkBtn.style.background  = '';
    // PTは宅建士証エリアを非表示
    var tkArea = document.getElementById('ai-takken-area');
    if (tkArea) tkArea.style.display = app.type === 'pt' ? 'none' : '';
  }

  // Timer reset
  clearInterval(timerInterval);
  timerStart = Date.now();
  timerInterval = setInterval(updateTimer, 1000);
  updateTimer();

  renderAppList();
  renderAppHeader(app);
  renderChecklist(app);
  updateProgress();

  // Show main
  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('app-hdr-wrap').style.display = 'block';

  // Reset verdict UI
  document.getElementById('result-banner').className = 'result-banner';
  document.getElementById('result-banner').innerHTML = '';
  document.getElementById('btn-calendly').style.display = 'none';
  document.getElementById('btn-reject').style.display = 'none';
  document.getElementById('verdict-note').value = '';
  document.getElementById('instant-fail-banner').classList.remove('show');

  // Auto-checks
  runAutoChecks(app);
}

// ================================================================
//  Timer
// ================================================================
function updateTimer() {
  const elapsed = Math.floor((Date.now() - timerStart) / 1000);
  const m = Math.floor(elapsed / 60).toString().padStart(2,'0');
  const s = (elapsed % 60).toString().padStart(2,'0');
  document.getElementById('timer-display').textContent = m + ':' + s;
}

// ================================================================
//  Header
// ================================================================
function renderAppHeader(app) {
  const TYPE_LABEL = { re:'🏠 不動産エージェント', hr:'👥 人材エージェント', pt:'🤝 パートナー' };
  const TYPE_COLOR = {
    re:'background:rgba(79,156,249,.15);color:#4f9cf9;border:1px solid rgba(79,156,249,.3)',
    hr:'background:rgba(20,184,166,.15);color:#2dd4bf;border:1px solid rgba(20,184,166,.3)',
    pt:'background:rgba(52,211,153,.15);color:#34d399;border:1px solid rgba(52,211,153,.3)',
  };
  const AVATAR = { re:'🏠', hr:'👥', pt:'🤝' };

  document.getElementById('app-avatar').textContent = AVATAR[app.type];
  document.getElementById('app-name').textContent   = app.name;
  document.getElementById('app-type-pill').textContent  = TYPE_LABEL[app.type];
  document.getElementById('app-type-pill').setAttribute('style',
    TYPE_COLOR[app.type] + ';padding:3px 10px;border-radius:5px;font-size:10px;font-weight:700');
  document.getElementById('app-sub-id').textContent    = app.id;
  document.getElementById('app-applied').textContent   = '申請日時：' + app.applied;

  // Info grid
  const cl = CHECKLISTS[app.type];
  const cells = [
    { label:'年齢',   val: app.age + '歳' },
    { label:'居住地', val: app.addr },
    { label:'審査目安', val: cl.estTime },
    { label:'紹介者',
      val: app.referralCode
        ? `<span class="referral-badge">🔗 ${app.referralName} (${app.referralRank})</span>`
        : '<span style="color:var(--muted)">なし</span>' },
  ];
  document.getElementById('info-grid').innerHTML =
    cells.map(c => `
      <div class="info-cell">
        <div class="ic-label">${c.label}</div>
        <div class="ic-val">${c.val}</div>
      </div>`).join('');
}

// ================================================================
//  Checklist render
// ================================================================
function renderChecklist(app) {
  const cl   = CHECKLISTS[app.type];
  const body = document.getElementById('checklist-body');

  body.innerHTML = cl.sections.map((sec, si) => `
    <div class="section" id="sec-${sec.id}">
      <div class="sec-hdr" onclick="toggleSec('${sec.id}')">
        <div class="sec-title">
          <span class="sec-icon">${sec.icon}</span>
          ${sec.title}
          <span class="sec-time">${sec.time}</span>
        </div>
        <div class="sec-meta">
          <span class="sec-progress" id="sec-prog-${sec.id}">0/${sec.items.length}</span>
          <span class="sec-chevron open" id="chev-${sec.id}">›</span>
        </div>
      </div>
      <div class="sec-body" id="sec-body-${sec.id}">
        ${sec.items.map((item, ii) => renderCheckItem(item, ii)).join('')}
      </div>
    </div>`).join('');
}

function renderCheckItem(item, ii) {
  const hasHint = item.hint ? `<span class="tag tag-info" style="margin-left:6px">${item.hint}</span>` : '';
  const hasNgTag = item.ngTag ? `<span class="tag tag-ng" style="margin-left:6px">${item.ngTag}</span>` : '';
  return `
    <div class="chk-item" id="row-${item.id}">
      <div class="chk-num">${String(ii+1).padStart(2,'0')}</div>
      <div class="chk-content">
        <div class="chk-label">
          ${item.label}${hasHint}${hasNgTag}
        </div>
        ${item.desc ? `<div class="chk-desc">${item.desc}</div>` : ''}
        ${item.ngAlert ? `<div class="chk-alert" id="alert-${item.id}">⚠️ ${item.ngAlert}</div>` : ''}
        <div class="item-memo" id="memo-${item.id}">
          <input type="text" placeholder="メモを入力（任意）" oninput="saveMemo('${item.id}',this.value)">
        </div>
      </div>
      <div class="status-btns">
        <button class="sb" id="sb-ok-${item.id}" title="問題なし（OK）"
                onclick="setCheck('${item.id}','ok')">✓</button>
        <button class="sb" id="sb-ng-${item.id}" title="問題あり（NG）"
                onclick="setCheck('${item.id}','ng')">✗</button>
        <button class="sb" id="sb-skip-${item.id}" title="スキップ（非該当）"
                onclick="setCheck('${item.id}','skip')">—</button>
      </div>
    </div>`;
}

// ================================================================
//  Auto-checks
// ================================================================
function runAutoChecks(app) {
  const cl = CHECKLISTS[app.type];
  let hasInstantFail = false;
  let ifReason = '';

  cl.sections.forEach(sec => {
    sec.items.forEach(item => {
      if (item.autoCheck) {
        const result = item.autoCheck(app);
        if (result) {
          setCheck(item.id, result, true);
          if (result === 'ng' && item.instantFail) {
            hasInstantFail = true;
            ifReason = item.ngAlert || item.label;
          }
        }
      }
    });
  });

  if (hasInstantFail) {
    const banner = document.getElementById('instant-fail-banner');
    banner.classList.add('show');
    document.getElementById('ifb-title').textContent = '即時不合格条件に該当';
    document.getElementById('ifb-reason').textContent = ifReason;
  }
}

// ================================================================
//  Check state
// ================================================================
function setCheck(itemId, state, silent = false) {
  checkState[itemId] = state;

  // Update button styles
  ['ok','ng','skip'].forEach(s => {
    const btn = document.getElementById(`sb-${s}-${itemId}`);
    if (!btn) return;
    btn.className = 'sb' + (state === s ? ` ${s}-active` : '');
  });

  // Update row style
  const row = document.getElementById(`row-${itemId}`);
  if (row) {
    row.classList.toggle('ok-row', state === 'ok');
    row.classList.toggle('ng-row', state === 'ng');
  }

  // Show/hide alert
  const alert = document.getElementById(`alert-${itemId}`);
  if (alert) alert.classList.toggle('show', state === 'ng');

  // Show memo on NG
  const memo = document.getElementById(`memo-${itemId}`);
  if (memo) memo.classList.toggle('show', state === 'ng');

  updateProgress();
  updateSectionProgress();
}

function saveMemo(itemId, val) {
  if (!checkState.memos) checkState.memos = {};
  checkState.memos[itemId] = val;
}

// ================================================================
//  Progress
// ================================================================
function updateProgress() {
  if (!currentApp) return;
  const cl      = CHECKLISTS[currentApp.type];
  const allItems = cl.sections.flatMap(s => s.items);
  const total    = allItems.length;
  const done     = allItems.filter(it => checkState[it.id]).length;
  const pct      = total > 0 ? Math.round((done / total) * 100) : 0;

  // Ring
  const circ = 2 * Math.PI * 31;
  document.getElementById('ring-fill').style.strokeDashoffset = circ * (1 - pct/100);
  document.getElementById('ring-fill').style.stroke =
    pct < 50 ? 'var(--orange)' : pct < 100 ? 'var(--blue)' : 'var(--green)';
  document.getElementById('ring-pct').textContent = pct + '%';
  document.getElementById('progress-text').textContent = done + ' / ' + total + ' 項目';
}

function updateSectionProgress() {
  if (!currentApp) return;
  const cl = CHECKLISTS[currentApp.type];
  cl.sections.forEach(sec => {
    const done  = sec.items.filter(it => checkState[it.id]).length;
    const el    = document.getElementById(`sec-prog-${sec.id}`);
    if (el) el.textContent = `${done}/${sec.items.length}`;
  });
}

function toggleSec(id) {
  const body = document.getElementById(`sec-body-${id}`);
  const chev = document.getElementById(`chev-${id}`);
  body.classList.toggle('collapsed');
  chev.classList.toggle('open');
}

// ================================================================
//  Verdict
// ================================================================
function setVerdict(v) {
  currentVerdict = v;
  const banner = document.getElementById('result-banner');
  const msgs = {
    pass: { cls:'rb-pass', icon:'✅', text:'合格 — 面接リンクを発行してください' },
    fail: { cls:'rb-fail', icon:'❌', text:'不合格 — 不合格通知メールを送信してください' },
    hold: { cls:'rb-hold', icon:'⏸', text:'保留 — 追加確認後に再判定してください' },
  };
  const m = msgs[v];
  banner.className = `result-banner show ${m.cls}`;
  banner.innerHTML = `<span style="font-size:20px">${m.icon}</span>${m.text}`;

  document.getElementById('btn-calendly').style.display = v === 'pass' ? 'block' : 'none';
  document.getElementById('btn-reject').style.display   = v === 'fail' ? 'block' : 'none';
}

// ================================================================
//  Actions
// ================================================================
function saveToKintone() {
  if (!currentApp) return;
  if (!currentVerdict) { alert('審査結果（合格/不合格/保留）を選択してください'); return; }
  const note = document.getElementById('verdict-note').value;

  // Update local state
  currentApp.status = currentVerdict === 'pass' ? 'pass' : currentVerdict === 'fail' ? 'fail' : 'hold';
  renderAppList();

  const verdictJP = { pass:'合格', fail:'不合格', hold:'保留' }[currentVerdict];

  if (currentVerdict === 'pass') {
    // 合格時: トークンURL発行 → LINE WORKSで送付
    const typePrefix = currentApp.type === 'pt' ? 'PT' : currentApp.type === 'hr' ? 'AG' : 'AG';
    const agNum = String(Math.floor(10000 + Math.random() * 9999));
    const token = typePrefix + agNum + '-' + Math.random().toString(36).substr(2,6).toUpperCase();
    const signupUrl = location.origin + location.pathname.replace('coreto-screening.html','coreto-agent-signup.html') + '?token=' + token;

    // Show token + URL in a copyable modal
    const box = document.createElement('div');
    box.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.7);display:flex;align-items:center;justify-content:center;z-index:9999;padding:20px';
    box.innerHTML = `
      <div style="background:#11141f;border:1px solid #2a3050;border-radius:16px;padding:28px;width:min(480px,100%);font-family:inherit">
        <div style="font-size:16px;font-weight:700;color:#e8eaf0;margin-bottom:6px">✅ 合格 — 入会URL発行</div>
        <div style="font-size:12px;color:#a0a8c0;margin-bottom:20px">${currentApp.name} さんの入会手続きURLです。LINE WORKSで送付してください。</div>
        <div style="font-size:10px;color:#5a6080;margin-bottom:4px;letter-spacing:1px">トークン</div>
        <div style="background:#090b13;border:1px solid #1e2235;border-radius:8px;padding:10px 14px;font-family:monospace;font-size:13px;color:#c9a840;margin-bottom:12px;word-break:break-all">${token}</div>
        <div style="font-size:10px;color:#5a6080;margin-bottom:4px;letter-spacing:1px">入会URL（コピーして送付）</div>
        <div id="signup-url-box" style="background:#090b13;border:1px solid #1e2235;border-radius:8px;padding:10px 14px;font-size:11px;color:#4f9cf9;margin-bottom:16px;word-break:break-all">${signupUrl}</div>
        <div style="display:flex;gap:8px">
          <button onclick="navigator.clipboard.writeText(document.getElementById('signup-url-box').textContent)" style="flex:1;background:rgba(201,168,76,.12);border:1px solid rgba(201,168,76,.3);color:#c9a840;border-radius:8px;padding:10px;cursor:pointer;font-family:inherit">📋 URLをコピー</button>
          <button onclick="this.closest('div[style*=fixed]').remove()" style="flex:1;background:transparent;border:1px solid #2a3050;color:#a0a8c0;border-radius:8px;padding:10px;cursor:pointer;font-family:inherit">閉じる</button>
        </div>
        <div style="margin-top:12px;font-size:10px;color:#5a6080;line-height:1.7">※ Kintoneに結果・トークンを保存済み<br>※ 合格通知・面接日程はCalendlyで確認してください</div>
      </div>`;
    document.body.appendChild(box);
  } else {
    alert(`✅ Kintoneに保存しました\n\n申請者：${currentApp.name}\n審査結果：${verdictJP}\n所見：${note || '（なし）'}\n\nKintoneの申請レコードが更新されました。`);
  }
}

function sendCalendly() {
  if (!currentApp) return;
  alert(`📅 Calendlyリンクを発行しました\n\n宛先：${currentApp.email}\n内容：面接予約リンク（有効期限：7日間）\n\n※本番ではCalendly API + Zapier経由で自動送信されます`);
}

function sendRejection() {
  if (!currentApp) return;
  const note = document.getElementById('verdict-note').value;
  alert(`✉ 不合格通知メールを送信しました\n\n宛先：${currentApp.email}\n理由：${note || '（審査基準を満たさなかったため）'}\n\n※本番ではZapier経由でGmail自動送信されます`);
}

// ================================================================
//  Detail modal
// ================================================================
function showDetailModal() {
  if (!currentApp) return;
  const app = currentApp;
  const TYPE = { re:'🏠 不動産エージェント', hr:'👥 人材エージェント', pt:'🤝 パートナー' };
  const motLen = (app.motivation||'').length;

  let specificHTML = '';
  if (app.type === 're') {
    specificHTML = `
      <div class="detail-sec">
        <div class="detail-sec-title">不動産エージェント 詳細</div>
        <div class="detail-row"><span class="dr-key">宅建士資格</span>
          <span class="dr-val">${app.takken
            ? `<span class="tag tag-ok">保有</span> ${app.takkenNo}（有効期限：${app.takkenExp}）`
            : '<span class="tag tag-warn">未保有</span>'}</span></div>
        <div class="detail-row"><span class="dr-key">業界経験</span><span class="dr-val">${app.experience}</span></div>
        <div class="detail-row"><span class="dr-key">実績</span><span class="dr-val">${app.expDetail||'—'}</span></div>
        <div class="detail-row"><span class="dr-key">得意エリア</span><span class="dr-val">${app.area||'—'}</span></div>
        <div class="detail-row"><span class="dr-key">得意物件</span><span class="dr-val">${app.propType||'—'}</span></div>
      </div>`;
  } else if (app.type === 'hr') {
    specificHTML = `
      <div class="detail-sec">
        <div class="detail-sec-title">人材エージェント 詳細</div>
        <div class="detail-row"><span class="dr-key">業界経験</span><span class="dr-val">${app.experience}</span></div>
        <div class="detail-row"><span class="dr-key">実績</span><span class="dr-val">${app.expDetail||'—'}</span></div>
        <div class="detail-row"><span class="dr-key">業務内容</span>
          <span class="dr-val">${(app.jobTypes||[]).join('、')||'—'}</span></div>
        <div class="detail-row"><span class="dr-key">得意業界</span><span class="dr-val">${app.industry||'—'}</span></div>
        <div class="detail-row"><span class="dr-key">得意職種</span><span class="dr-val">${app.occupation||'—'}</span></div>
      </div>`;
  } else if (app.type === 'pt' && app.corpName) {
    specificHTML = `
      <div class="detail-sec">
        <div class="detail-sec-title">法人情報</div>
        <div class="detail-row"><span class="dr-key">法人名</span><span class="dr-val">${app.corpName}</span></div>
        <div class="detail-row"><span class="dr-key">法人番号</span><span class="dr-val">${app.corpNo}</span></div>
        <div class="detail-row"><span class="dr-key">代表者</span><span class="dr-val">${app.repName}</span></div>
      </div>`;
  }

  document.getElementById('modal-body').innerHTML = `
    <div class="detail-sec">
      <div class="detail-sec-title">基本情報</div>
      <div class="detail-row"><span class="dr-key">氏名</span><span class="dr-val">${app.name}（${app.kana||'—'}）</span></div>
      <div class="detail-row"><span class="dr-key">申請タイプ</span><span class="dr-val">${TYPE[app.type]}</span></div>
      <div class="detail-row"><span class="dr-key">年齢</span><span class="dr-val">${app.age}歳</span></div>
      <div class="detail-row"><span class="dr-key">住所</span><span class="dr-val">${app.addr}</span></div>
      <div class="detail-row"><span class="dr-key">メール</span><span class="dr-val">${app.email}</span></div>
      <div class="detail-row"><span class="dr-key">電話</span><span class="dr-val">${app.tel}</span></div>
      <div class="detail-row"><span class="dr-key">申請日時</span><span class="dr-val">${app.applied}</span></div>
      <div class="detail-row"><span class="dr-key">申請ID</span><span class="dr-val" style="font-family:'DM Mono',monospace">${app.id}</span></div>
    </div>
    ${specificHTML}
    <div class="detail-sec">
      <div class="detail-sec-title">紹介コード</div>
      ${app.referralCode
        ? `<div class="referral-badge">🔗 ${app.referralCode}（${app.referralName} / ${app.referralRank}）</div>`
        : '<span style="font-size:12px;color:var(--muted)">なし</span>'}
    </div>
    <div class="detail-sec">
      <div class="detail-sec-title">志望動機</div>
      <div class="motivation-box">${(app.motivation||'').replace(/\n/g,'<br>')}</div>
      <div class="char-count">${motLen}文字</div>
    </div>`;

  document.getElementById('modal-overlay').classList.add('show');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('show');
}
</script>
</body>
</html>
